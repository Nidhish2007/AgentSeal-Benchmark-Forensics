# Large local artifacts. Use Git LFS only if you intentionally commit these.
*.sqlite filter=lfs diff=lfs merge=lfs -text
*.bloom filter=lfs diff=lfs merge=lfs -text
*.parquet filter=lfs diff=lfs merge=lfs -text
*.whl filter=lfs diff=lfs merge=lfs -text

# Text normalization
*.py text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
